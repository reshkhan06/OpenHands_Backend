DATABASE_URL="sqlite:///./donation.db"

# Email (required for verification & notifications). Gmail: use App Password, not account password.
# https://support.google.com/accounts/answer/185833
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=your@gmail.com

SECRET_KEY="your-super-secret-key"
FRONTEND_URL="http://localhost:5173"
# Optional: admin email to receive notification when a new NGO verifies (pending approval)
ADMIN_EMAIL="admin@gmail.com"
RAZORPAY_KEY_ID="your key id"
RAZORPAY_KEY_SECRET="your key secret"